# FoodPlan Environment Configuration
# Copy this file to .env and fill in the values.

# ─── Required ────────────────────────────────────────────────────────
# JWT signing secret (base64-encoded, minimum 256-bit / 32 bytes).
# Generate one with: openssl rand -base64 32
JWT_SECRET=

# Frontend URL for CORS (only needed for production deployments).
# Default for local dev: http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Optional: Slack Error Notifications ─────────────────────────────
# Bot token and channel ID for posting application errors to Slack.
# SLACK_ERROR_TOKEN=xoxb-your-bot-token
# SLACK_ERROR_CHANNEL=C0YOUR_CHANNEL_ID

# ─── Optional: Kroger API (Fred Meyer, Ralphs, etc.) ────────────────
# Register a free developer account at https://developer.kroger.com
# to get client credentials. Find your store's location ID via the
# Kroger Location API: https://developer.kroger.com/api-ref/location
# KROGER_CLIENT_ID=
# KROGER_CLIENT_SECRET=
# KROGER_LOCATION_ID=

# ─── Optional: CHEF'STORE / Cash 'n Carry (Algolia) ─────────────────
# Defaults in application.properties work out of the box for any
# CHEF'STORE location. Override to use a different store number:
# CHEFSTORE_ALGOLIA_APP_ID=70KQ5FEQ31
# CHEFSTORE_ALGOLIA_API_KEY=48035a5322b28e6485ae9f3b235b150a
# CHEFSTORE_STORE_NUMBER=553
